# =========================================================================
# graphify-release-announcer — configuration
# Copy to `.env` and fill in. EVERYTHING here is optional with sane defaults.
# For the core use (track releases + generate Discord messages to copy-paste)
# you don't need to set anything. Add ANTHROPIC_API_KEY for nicer wording, and
# the DISCORD_* vars only if you want the optional `post` command.
# =========================================================================

# --- Source repo (GitHub) ---
# The repo moved from safishamsi/graphify -> Graphify-Labs/graphify (old still redirects).
GITHUB_REPO=Graphify-Labs/graphify
# Optional: a GitHub token lifts the 60 req/hr anon rate limit (any repo-read scope).
GITHUB_TOKEN=

# --- Product identity (shown in the announcement) ---
PRODUCT_NAME=Graphify
PYPI_PACKAGE=graphifyy
# Trails the "is now live" title. Discord custom emoji format: <:name:id>
# Default = Graphify Labs server emoji (id 1526877858390081616).
# RELEASE_EMOJI=<:graphify:1526877858390081616>
# Or set name + id separately (used when RELEASE_EMOJI is unset):
RELEASE_EMOJI_NAME=graphify
RELEASE_EMOJI_ID=1526877858390081616

# --- LLM polish (Anthropic Claude) — OPTIONAL ---
# With a key set, messy release notes are rewritten into clean, human-friendly
# highlights. Without a key, a deterministic parser is used instead (still good).
ANTHROPIC_API_KEY=
# Model used to rewrite notes (matches the social-bot ecosystem default).
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Discord posting — OPTIONAL (only if you use the `post` command) ---
# Leave blank to just generate messages you paste yourself (the default workflow).
# Bot token + the #production-releases channel id. Same bot you use elsewhere is fine.
DISCORD_TOKEN=
PRODUCTION_RELEASES_CHANNEL_ID=
# Role that gets pinged at the top (the "@Production Releases" role). Leave blank
# to render a plain "@Production Releases" text mention that does NOT ping.
PRODUCTION_RELEASES_ROLE_ID=
# What the top mention reads as when no role id is set (or in copy-paste output).
RELEASE_ROLE_NAME=Production Releases

# --- Formatting knobs ---
# Post style, modelled on the two Coolify #production-releases admins:
#   peak   = big H1 title, "## Release Highlights" + stats line, bold emoji section
#            headers, flat bullets. (clean & prominent — the default)
#   shadow = inline "@role — **title**" line, bold section labels with hollow nested
#            sub-bullets, no highlights heading. (denser, classic changelog look)
POST_THEME=peak
# Discord one-message budget. Free=2000, Nitro=4000.
# Coolify's long catch-ups (~3800) work because Peak has Nitro + short bullets.
# Set DISCORD_NITRO=true if your Discord account has Nitro (budget 3900).
# Or set DISCORD_CHAR_LIMIT=3900 directly. 0 = never auto-fit.
DISCORD_NITRO=false
# DISCORD_CHAR_LIMIT=1990
# Max bullet items per section. 0 = show all (Coolify-style). Set a number (e.g. 8)
# to cap long sections; the "Full release notes" link always covers the rest.
MAX_ITEMS_PER_SECTION=0
# Clean, Coolify-style bullets: strip (#123) issue/PR refs and "thanks @x" credits.
# Set to false if you want the dev-detailed version (refs + contributor credits kept).
CLEAN_STYLE=true

# --- #announcements studio ---
# Reuse the same Bearer Token as graphify-social-bot / graphify-tweet-agent
# (Twitter Developer Portal → Project → Keys and tokens → Bearer Token).
# On Vercel: Project → Settings → Environment Variables → paste TWITTER_BEARER_TOKEN.
TWITTER_BEARER_TOKEN=
# Comma-separated X handles to watch (no @).
ANNOUNCE_HANDLES=safishamsii,graphify
# Star milestones that surface as draftable #announcements posts.
STAR_MILESTONES=80000,90000,100000
# Ping line for big announcements (@everyone or a role mention text).
ANNOUNCE_PING=@everyone
# How many recent tweets to pull per handle (5–100).
ANNOUNCE_TWEETS_PER_HANDLE=8

# --- Live web coverage (Exa) + RSS ---
# Exa API key: https://dashboard.exa.ai/api-keys  (same product as Cursor Exa MCP)
EXA_API_KEY=
# Defaults run 5 parallel passes (news + personal blogs + deep). Optional overrides:
# EXA_QUERIES=recent Graphify Labs coverage|graphifyy open source knowledge graph articles
# EXA_NUM_RESULTS=12
# EXA_SEARCH_TYPE=deep-lite
# EXA_DAYS_LOOKBACK=21
# Optional comma-separated RSS feeds (defaults: Google News + HN keyword feeds)
# ANNOUNCE_RSS_FEEDS=https://news.google.com/rss/search?q=Graphify,https://hnrss.org/newest?q=Graphify
# ANNOUNCE_RSS_MAX_PER_FEED=12
# ANNOUNCE_RSS_MAX_AGE_DAYS=21

# --- Announcement images (checkbox: Create image too) ---
# Claude brainstorms a Graphify-branded brief (DESIGN tokens + graph-G), then SVG.
# Anthropic cannot emit PNG; optional OpenAI fills that gap.
# Default anthropic = Claude brief + SVG (no OpenAI needed).
# Use auto if you later add OPENAI_API_KEY for raster PNG.
# ANNOUNCE_IMAGE_ENGINE=anthropic|auto|openai
ANNOUNCE_IMAGE_ENGINE=anthropic
# ANTHROPIC_IMAGE_MODEL=claude-sonnet-4-6
# ANNOUNCE_IMAGE_THINKING_BUDGET=8000
# OPENAI_API_KEY=
# OPENAI_IMAGE_MODEL=gpt-image-1.5
# OPENAI_IMAGE_QUALITY=high
